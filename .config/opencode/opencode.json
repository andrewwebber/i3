{
  "$schema": "https://opencode.ai/config.json",
  "model": "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_XL",
  "small_model": "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_XL",
  "enabled_providers" : ["bladerunner", "llama.cpp"],
  "permission": {
    "question": "allow",
    "bash": {
      "*": "ask",
      "cargo test *": "allow",
      "cargo clippy *": "allow",
      "rm *": "deny",
    },
    "webfetch": "ask",
    "read": {
      "*": "allow",
      "credentials": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "provider": {
    "bladerunner": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Bladerunner",
      "options": {
        "baseURL": "{env:OPENCODE_SERVER}",
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "qwen.qwen3-235b-a22b-2507-v1:0": {
          "name": "qwen.qwen3-235b-a22b-2507-v1:0",
          "limit": {
            "context": 132000,
            "output": 65536
          }
        }
      }
    },
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8012/v1"
      },
      "models": {
        "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_XL": {
          "name": "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_XL",
          "limit": {
            "context": 132000,
            "output": 65536
          }
        }
      }
    }
  },
  "mcp": {
    "gitlab_mcp": {
      "type": "remote",
      "url": "http://127.0.0.1:3000/sse",
      "enabled": true
    },
  }
}
